{
  "name": "obsidian-video-summary-plugin",
  "version": "2.1.4",
  "description": "将视频链接、本地音视频和文稿整理为结构化 Obsidian 笔记",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "lint": "eslint --ext .ts .",
    "lint:fix": "eslint --ext .ts . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write ."
  },
  "keywords": [
    "obsidian",
    "plugin",
    "video",
    "summary",
    "transcript",
    "notes",
    "automation",
    "n8n",
    "knowledge-management"
  ],
  "author": "Rexx",
  "license": "MIT",
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.30",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "builtin-modules": "^3.2.0",
    "esbuild": "^0.28.0",
    "eslint": "^8.57.1",
    "obsidian": "^1.13.0",
    "prettier": "^3.8.3",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  }
}
